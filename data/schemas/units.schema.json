{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OlundarUnit",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["id", "name", "hp", "attack", "range", "move", "sight", "trainTurns", "cost", "requires", "tags"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "role": { "type": "string" },
      "faction": { "type": "string" },
      "glyph": { "type": "string" },
      "hp": { "type": "number", "minimum": 1 },
      "attack": { "type": "number", "minimum": 0 },
      "range": { "type": "number", "minimum": 1 },
      "move": { "type": "number", "minimum": 1 },
      "sight": { "type": "number", "minimum": 1 },
      "armor": { "type": "number" },
      "upkeep": { "type": "object" },
      "cost": { "type": "object" },
      "trainTurns": { "type": "integer", "minimum": 1 },
      "requires": { "type": "array", "items": { "type": "string" } },
      "tags": { "type": "array", "items": { "type": "string" } },
      "text": { "type": "string" },
      "artPath": { "type": "string" }
    }
  }
}
